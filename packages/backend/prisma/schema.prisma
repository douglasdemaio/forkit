generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id            String     @id @default(uuid())
  walletAddress String     @unique
  name          String
  metadata      Json
  acceptedMints String[]
  createdAt     DateTime   @default(now())
  menuItems     MenuItem[]
  orders        Order[]    @relation("RestaurantOrders")
}

model MenuItem {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  name         String
  description  String
  price        Decimal
  imageCid     String     @default("")
  category     String
  available    Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Driver {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  metadata      Json
  zones         Json     // DeliveryZone[]
  createdAt     DateTime @default(now())
  orders        Order[]  @relation("DriverOrders")
}

model Customer {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  metadata      Json
  createdAt     DateTime @default(now())
  orders        Order[]  @relation("CustomerOrders")
}

model Order {
  id              String          @id @default(uuid())
  onChainOrderId  BigInt          @unique
  customerId      String
  customer        Customer        @relation("CustomerOrders", fields: [customerId], references: [id])
  restaurantId    String
  restaurant      Restaurant      @relation("RestaurantOrders", fields: [restaurantId], references: [id])
  driverId        String?
  driver          Driver?         @relation("DriverOrders", fields: [driverId], references: [id])
  items           Json            // [{menuItemId, quantity, price}]
  tokenMint       String
  foodTotal       Decimal
  deliveryFee     Decimal
  protocolFee     Decimal
  depositAmount   Decimal
  escrowTarget    Decimal         // total needed in escrow
  escrowFunded    Decimal         @default(0) // total funded so far
  status          String
  codeAHash       String
  codeBHash       String
  shareLink       String?         @unique // shareable link for contributions
  createdAt       DateTime        @default(now())
  settledAt       DateTime?
  contributions   Contribution[]
}

model Contribution {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  walletAddress   String
  amount          Decimal
  txSignature     String   // on-chain tx signature
  createdAt       DateTime @default(now())

  @@unique([orderId, walletAddress])
}
